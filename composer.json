{
    "name": "pingark/pingark-laravel",
    "description": "First-class PingArk integration for Laravel: auto-register scheduled tasks, ping start/success/failure, and capture durations and exit context.",
    "keywords": ["laravel", "cron", "monitoring", "heartbeat", "scheduler", "pingark"],
    "homepage": "https://pingark.com/docs/laravel-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Abhishek Das",
            "email": "abhishek@virtueplanet.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.5|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "PingArk\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PingArk\\Laravel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "laravel": {
            "providers": [
                "PingArk\\Laravel\\PingArkServiceProvider"
            ],
            "aliases": {
                "PingArk": "PingArk\\Laravel\\Facades\\PingArk"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
